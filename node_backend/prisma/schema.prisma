generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ChatLog {
  id        Int      @id @default(autoincrement())
  userText  String
  aiIntent  String?
  aiEmotion String?
  createdAt DateTime @default(now())
}

model Feedback {
  id        Int      @id @default(autoincrement())
  rating    Int
  comments  String?
  createdAt DateTime @default(now())
}

model SystemMetric {
  id        Int      @id @default(autoincrement())
  cpuUsage  Float?
  memUsage  Float?
  createdAt DateTime @default(now())
}

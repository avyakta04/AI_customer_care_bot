# ============================================================
# ECHOMIND Frontend – Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env      (Windows CMD)
#   cp .env.example .env        (PowerShell / Linux / Mac)
#
# All variables MUST be prefixed with VITE_ to be accessible
# inside the React/Vite application.
# ============================================================

# --- Backend API URL ---
# Default points to local FastAPI server
VITE_API_URL=http://localhost:8000

# --- WebSocket URL ---
# Used by src/services/socket.js
VITE_WS_URL=ws://localhost:8000

# --- Application ---
VITE_APP_NAME=ECHOMIND
VITE_APP_VERSION=4.2.0

# --- Feature Flags ---
VITE_ENABLE_VOICE_ANALYSIS=true
VITE_ENABLE_MEMORY_RETRIEVAL=true
VITE_ENABLE_HINDSIGHT_LEARNING=true
VITE_ENABLE_AI_SUPERVISOR=true

# ============================================================
# ECHOMIND Backend – Environment Variables Template
# ============================================================
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
# The app reads these via config.py using os.getenv().
# ============================================================

# --- Database ---
# SQLite (default):
DATABASE_URL=sqlite:///./echomind.db
# PostgreSQL (uncomment and set):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/echomind

# --- Paths (leave blank to use defaults) ---
# MODELS_DIR=./backend/models
# DATASETS_DIR=./backend/datasets

# --- Sentence Transformer ---
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# --- CORS (comma-separated list) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Hindsight Learning ---
HINDSIGHT_RETRAIN_THRESHOLD=5

# --- Safety ---
SAFETY_THRESHOLD=0.7

# --- Audio ---
AUDIO_SAMPLE_RATE=22050
AUDIO_MAX_DURATION_SEC=30

# --- Logging ---
LOG_LEVEL=INFO

# --- Debug ---
APP_DEBUG=false
